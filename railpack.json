{
  "$schema": "https://schema.railpack.com",
  "packages": {
    "node": "20",
    "python": "3.13"
  },
  "build": {
    "commands": [
      "cd theme/static_src && npm install --include=dev",
      "python manage.py tailwind build",
      "python manage.py collectstatic --noinput --clear",
      "ls -la theme/static/css/dist/",
      "find theme -name styles.css"
    ]
  }
}